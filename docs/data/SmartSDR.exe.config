  <userSettings>
    <SmartSDR.Properties.Settings>
      <setting name="MainWindowPlacement" serializeAs="String">
        <value />
      </setting>
      <setting name="SetupWindowPlacement" serializeAs="String">
        <value />
      </setting>
      <setting name="FlexControlEnabled" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="IsTXPanelOpen" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="FavoriteMode0" serializeAs="String">
        <value>USB</value>
      </setting>
      <setting name="FavoriteMode1" serializeAs="String">
        <value>CW</value>
      </setting>
      <setting name="FavoriteMode2" serializeAs="String">
        <value>AM</value>
      </setting>
      <setting name="UpdateSettings" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="ButtonLeftFunction" serializeAs="String">
        <value>RIT</value>
      </setting>
      <setting name="ButtonMiddleFunction" serializeAs="String">
        <value>Master AF</value>
      </setting>
      <setting name="ButtonRightFunction" serializeAs="String">
        <value>XIT</value>
      </setting>
      <setting name="PrimaryKnobFunction" serializeAs="String">
        <value>Tune Slice</value>
      </setting>
      <setting name="LastButtonPressed" serializeAs="String">
        <value>Knob</value>
